# Olly Henson Coaching — Marketing OS
# Copy this file to .env and fill in your real values.
# The .env file is gitignored and will never be committed to GitHub.

# ----------------------------------------------------------
# NOTION
# Get your token at: notion.so/my-integrations
# Create a new integration, copy the Internal Integration Token
# Then share your Notion pages/databases with the integration
# ----------------------------------------------------------
NOTION_API_TOKEN=your_notion_internal_integration_token_here

# Parent page URL
# Open your AI OS page in Notion and paste the full URL here
# e.g. https://www.notion.so/Your-Workspace/AI-OS-abc123...
NOTION_PARENT_PAGE_URL=your_ai_os_notion_page_url_here

# Notion database IDs (leave blank — Claude will fill these in after creating the databases)
NOTION_INSTAGRAM_DATABASE_ID=
NOTION_YOUTUBE_DATABASE_ID=

# ----------------------------------------------------------
# GOHIGHLEVEL (future)
# Get your API key at: app.gohighlevel.com > Settings > Integrations
# ----------------------------------------------------------
GHL_API_KEY=your_gohighlevel_api_key_here
GHL_LOCATION_ID=your_gohighlevel_location_id_here

# ----------------------------------------------------------
# ZAPIER (future)
# Used to connect tools that don't have direct MCP support
# ----------------------------------------------------------
ZAPIER_API_KEY=your_zapier_api_key_here
